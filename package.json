{
  "name": "ae-meta-mcp",
  "version": "0.1.0",
  "description": "Lightweight After Effects MCP: run ExtendScript in a running AE via ae_exec.",
  "type": "module",
  "main": "./mcp/index.mjs",
  "bin": {
    "ae-meta-mcp": "./mcp/index.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node ./mcp/index.mjs",
    "setup:cursor": "node ./scripts/setup-cursor.mjs",
    "build:playable": "node ./scripts/build-playable-lottie.mjs",
    "export:optimize": "node ./scripts/optimize-lottie.mjs",
    "slot-board:editor": "node ./scripts/serve-slot-board-editor.mjs",
    "test:slot-board-anim": "node ./scripts/test-slot-board-anim.mjs",
    "pack:effect": "node ./scripts/pack-effect-frames.mjs examples/effect"
  },
  "keywords": [
    "mcp",
    "after-effects",
    "extendscript",
    "cep",
    "cursor"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "sharp": "^0.35.2"
  }
}
